# ─── App ───────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# ─── PostgreSQL ────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/flixvideo

# ─── MongoDB ───────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/flixvideo

# ─── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ───────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret
JWT_REFRESH_SECRET=your_refresh_secret
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# ─── TMDB API ──────────────────────────────────────────────────────
TMDB_API_KEY=your_tmdb_api_key
TMDB_API_BASE_URL=https://api.themoviedb.org/3

# ─── YouTube API ───────────────────────────────────────────────────
YOUTUBE_API_KEY=your_youtube_api_key

# ─── Claude AI ─────────────────────────────────────────────────────
CLAUDE_API_KEY=your_claude_api_key
CLAUDE_MODEL=claude-sonnet-4-20250514

# ─── AWS S3 ────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=flixvideo-storage

# ─── Stripe ────────────────────────────────────────────────────────
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# ─── M-Pesa (Safaricom) ────────────────────────────────────────────
MPESA_CONSUMER_KEY=your_mpesa_consumer_key
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret
MPESA_SHORTCODE=your_mpesa_shortcode
MPESA_PASSKEY=your_mpesa_passkey
MPESA_CALLBACK_URL=https://yourdomain.com/api/webhooks/mpesa

# ─── NOWPayments (Crypto) ──────────────────────────────────────────
NOWPAYMENTS_API_KEY=your_nowpayments_api_key
NOWPAYMENTS_IPN_SECRET=your_nowpayments_ipn_secret
NOWPAYMENTS_CALLBACK_URL=https://yourdomain.com/api/webhooks/crypto

# ─── Email (SendGrid) ──────────────────────────────────────────────
SENDGRID_API_KEY=your_sendgrid_api_key
EMAIL_FROM=noreply@flixvideo.com

# ─── Sentry ────────────────────────────────────────────────────────
SENTRY_DSN=your_sentry_dsn

# ─── Monitoring ────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=AdminFV@254!

# ─── Mongo Express (local dev only) ────────────────────────────────
MONGO_EXPRESS_USER=adminwaru
MONGO_EXPRESS_PASSWORD=AdminFV@254!

# ─── Rate Limiting ─────────────────────────────────────────────────
RATE_LIMIT_WINDOW=15m
RATE_LIMIT_MAX_REQUESTS=100

# ─── PGAdmin (local dev only) ───────────────────────────────────────
PGADMIN_PASSWORD=AdminFV@254!