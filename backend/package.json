{
  "name": "flixvideo-backend",
  "version": "1.0.0",
  "description": "FlixVideo Backend API - AI-Powered Movie Discovery Platform",
  "main": "server.js",
  "author": "WaruTech",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "yarn": ">=1.22.0"
  },
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "start:prod": "NODE_ENV=production node server.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\"",
    "test": "echo \"Tests not yet implemented\" && exit 0",
    "test:watch": "echo \"Tests not yet implemented\" && exit 0",
    "test:coverage": "echo \"Tests not yet implemented\" && exit 0",
    "migrate:create": "node scripts/create-migration.js",
    "migrate:up": "node scripts/run-migrations.js",
    "migrate:down": "node scripts/rollback-migration.js",
    "seed": "node scripts/seed.js",
    "seed:dev": "NODE_ENV=development node scripts/seed.js",
    "seed:test": "NODE_ENV=test node scripts/seed.js",
    "db:backup": "node scripts/backup-db.js",
    "db:restore": "node scripts/restore-db.js",
    "jobs:test": "node test-jobs.js",
    "jobs:crypto": "node test-crypto-payment.js",
    "jobs:exchange": "node test-exchange-rates.js",
    "docker:up": "docker-compose up -d postgres mongodb redis",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:clean": "docker-compose down -v",
    "clean": "rm -rf node_modules coverage .nyc_output",
    "fresh": "yarn clean && yarn install"
  },
